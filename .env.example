PORT=8004
LOG_LEVEL=info
LOG_FORMAT=pretty
DATABASE_PATH=./data/bridge-table-service.db
DASHBOARD_SECRET=devsecret
# Shared with the bridge-classroom API, which mints join tickets this
# service verifies offline. Generate with: openssl rand -hex 32
TICKET_SECRET=devticketsecret
